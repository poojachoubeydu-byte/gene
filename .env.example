# Apex Bioinformatics — API Keys
# Copy this file to .env and fill in your keys.
# .env is in .gitignore and will NOT be committed to git.
#
# AI Engine waterfall: Gemini 2.5 Flash → Groq Llama 3 → Rule-Based (offline)
# You only need ONE key. Gemini is primary; Groq is the free fallback.
#
# Get a free Gemini key: https://aistudio.google.com/app   (primary, no card)
# Get a free Groq key  : https://console.groq.com          (fallback, no card)

# PRIMARY — Google Gemini 2.5 Flash
GEMINI_API_KEY=your_gemini_key_here

# FALLBACK — Groq Llama 3 70B
GROQ_API_KEY=your_groq_key_here
